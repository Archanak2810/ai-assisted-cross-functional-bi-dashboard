# Copy this file to .streamlit/secrets.toml for local development.
# For Streamlit Cloud: paste these values in App Settings → Secrets.
# NEVER commit secrets.toml to GitHub.

[postgres]
host     = "PASTE_YOUR_NEON_POOLER_HOST_HERE"
port     = 5432
database = "neondb"
user     = "neondb_owner"
password = "PASTE_YOUR_NEON_PASSWORD_HERE"
sslmode  = "require"
